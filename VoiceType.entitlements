<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: allow JIT for WhisperKit CoreML -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Audio input for recording -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Outgoing network for OpenAI API + model download -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Keychain access for API key storage -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.skhe.voicetype</string>
    </array>
</dict>
</plist>
